# === Variabili d'ambiente (impostale su Vercel → Project → Settings → Environment Variables) ===

# Notion — integration token (https://www.notion.so/my-integrations), inizia con "ntn_" o "secret_"
NOTION_TOKEN=

# ID del database "📲 Registrazioni Workshop"
NOTION_DATABASE_ID=37337aed983381479efdf5a01a29058f

# Stripe — chiave segreta (sk_live_... per produzione, sk_test_... per i test)
STRIPE_SECRET_KEY=

# Stripe — secret del webhook (whsec_...), lo ottieni creando l'endpoint webhook su Stripe
STRIPE_WEBHOOK_SECRET=
